---
import { SITE } from '../config';
---

<header class="site-header">
  <div class="header-inner">
    <a href="/" class="logo">
      <span class="logo-box">M</span>
      <span class="logo-name">{SITE.name.split(' ')[0]} {SITE.name.split(' ')[1]}</span>
    </a>
    <nav class="nav">
      <a href="#php-world">PHP World</a>
      <a href="#ai-world">AI World</a>
      <a href="#writing">Writing</a>
      <a href="#hire-me">Hire Me</a>
      <a href="/resume.pdf" class="nav-resume" download>resume.pdf ↓</a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1.5px solid var(--ink);
    background: var(--paper);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .header-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 18px 28px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .logo-box {
    width: 28px;
    height: 28px;
    border: 1.5px solid var(--ink);
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--mono);
    font-size: 12px;
    font-weight: 700;
    flex-shrink: 0;
  }

  .logo-name {
    font-family: var(--hand);
    font-size: 18px;
    color: var(--ink);
  }

  .nav {
    display: flex;
    align-items: center;
    gap: 18px;
    font-family: var(--mono);
    font-size: 11px;
  }

  .nav a {
    color: var(--ink-soft);
    text-decoration: none;
    transition: color 0.15s;
  }

  .nav a:hover {
    color: var(--ink);
  }

  .nav-resume {
    padding: 3px 10px;
    border: 1.5px solid var(--ink);
    border-radius: 999px;
    background: var(--accent);
    color: #fff !important;
  }

  .nav-resume:hover {
    opacity: 0.88;
  }

  @media (max-width: 640px) {
    .nav { display: none; }
  }
</style>
