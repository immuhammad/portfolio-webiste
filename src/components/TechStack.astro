---
import { SITE } from '../config';

const columns = [
  {
    label: 'PHP World',
    pills: ['PHP 8', 'Laravel', 'Magento 2', 'MySQL', 'Shopify'],
  },
  {
    label: 'AI World (in flight)',
    pills: ['Python', 'PyTorch', 'LangChain', 'Pandas', 'SQL'],
  },
  {
    label: 'Glue',
    pills: ['Docker', 'Git', 'Linux', 'REST', 'GraphQL'],
  },
];
---

{SITE.sections.stack && (
  <section class="tech-stack" id="php-world">
    <div class="ts-inner">

      <div class="section-title-row">
        <span class="title-prefix mono">❯</span>
        <span class="title-text hand">Stack</span>
        <span class="title-sub mono">— what I reach for</span>
      </div>

      <div class="ts-grid">
        {columns.map(col => (
          <div class="ts-box">
            <!-- Floating label chip on the top border -->
            <span class="ts-label mono">{col.label}</span>
            <div class="ts-pills">
              {col.pills.map(p => <span class="ts-pill mono">{p}</span>)}
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>
)}

<style>
  .tech-stack {
    padding: 8px 28px 32px;
  }

  .ts-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  /* Section title */
  .section-title-row {
    display: flex;
    align-items: baseline;
    gap: 10px;
    margin-bottom: 16px;
  }

  .title-prefix { font-size: 14px; color: var(--accent); }
  .title-text   { font-size: 28px; }
  .title-sub    { font-size: 11px; color: var(--ink-soft); }

  /* 3-col grid */
  .ts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
  }

  /* Box: dashed border + floating label (wireframe Box component) */
  .ts-box {
    border: 1.5px dashed var(--ink);
    border-radius: 4px;
    padding: 12px;
    padding-top: 16px;
    position: relative;
    background: var(--paper);
  }

  /* Floating label chip sits on the top border */
  .ts-label {
    position: absolute;
    top: -9px;
    left: 10px;
    background: var(--paper);
    padding: 0 6px;
    font-size: 9px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }

  /* Pills — rounded, dashed border */
  .ts-pills {
    display: flex;
    flex-wrap: wrap;
    margin-top: 4px;
  }

  .ts-pill {
    display: inline-block;
    padding: 3px 9px;
    border: 1.5px dashed var(--ink);
    border-radius: 999px;
    font-size: 10px;
    margin-right: 5px;
    margin-bottom: 5px;
    color: var(--ink);
  }

  @media (max-width: 680px) {
    .ts-grid { grid-template-columns: 1fr; }
    .title-sub { display: none; }
  }
</style>
