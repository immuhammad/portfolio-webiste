---
import { SITE } from '../config';

const columns = [
  {
    label: 'PHP World',
    pills: ['PHP 8', 'Laravel', 'Magento 2', 'Hyva', 'MySQL', 'Redis', 'Shopify', 'Elasticsearch', 'RabbitMQ', 'Varnish', 'Composer', 'PHPUnit'],
  },
  {
    label: 'AI / Data Engineering',
    pills: ['Python', 'PyTorch', 'Scikit-learn', 'XGBoost', 'LangChain', 'LlamaIndex', 'HuggingFace', 'OpenAI API', 'Ollama', 'ChromaDB', 'Pandas', 'SQL', 'Airflow', 'dbt', 'FastAPI', 'MLflow'],
  },
  {
    label: 'Glue',
    pills: ['Docker', 'Git', 'Linux', 'Bash', 'Nginx', 'REST', 'GraphQL', 'GitHub Actions', 'AWS', 'Postman', 'Webpack'],
  },
];

const certsEarned = [
  {
    title: 'Adobe Certified Professional',
    sub:   'Adobe Commerce Developer',
    issuer: 'Adobe · 2022',
    url: '',
  },
  {
    title: 'Machine Learning Specialization',
    sub:   'Supervised ML · Advanced Algorithms · Unsupervised / Reinforcement Learning',
    issuer: 'DeepLearning.AI / Stanford Online',
    url: 'https://www.coursera.org/account/accomplishments/specialization/24TCXOEE23DJ',
  },
];

const certsWip = [
  {
    title: 'Claude Certified Architect',
    issuer: 'Anthropic',
  },
  {
    title: 'AWS ML Specialty',
    issuer: 'Amazon Web Services',
  },
];
---

{SITE.sections.stack && (
  <section class="tech-stack" id="php-world">
    <div class="ts-inner">

      <div class="section-title-row">
        <span class="title-prefix mono">❯</span>
        <span class="title-text hand">Stack</span>
        <span class="title-sub mono">— what I reach for</span>
      </div>

      <div class="ts-grid">
        {columns.map(col => (
          <div class="ts-box">
            <span class="ts-label mono">{col.label}</span>
            <div class="ts-pills">
              {col.pills.map(p => <span class="ts-pill mono">{p}</span>)}
            </div>
          </div>
        ))}
      </div>

      <!-- Certifications — paired row grid so dividers align across columns -->
      <div class="cert-box ts-box" id="certifications">
        <span class="ts-label mono">// certifications</span>

        <div class="cert-grid">

          <!-- Column headers -->
          <p class="cert-col-label mono">✓ earned</p>
          <p class="cert-col-label cert-col-label--wip mono">○ in progress</p>

          <!-- Row 1 -->
          <div class="cert-item">
            <div class="cert-name-row">
              <span class="cert-name mono">{certsEarned[0].title}</span>
            </div>
            {certsEarned[0].sub && <p class="cert-sub mono">{certsEarned[0].sub}</p>}
            <p class="cert-issuer mono">{certsEarned[0].issuer}</p>
          </div>
          <div class="cert-item cert-item--wip">
            <div class="cert-name-row">
              <span class="cert-name mono">{certsWip[0].title}</span>
              <span class="wip-badge mono">wip</span>
            </div>
            <p class="cert-issuer mono">{certsWip[0].issuer}</p>
          </div>

          <!-- Row 2 -->
          <div class="cert-item cert-item--last">
            <div class="cert-name-row">
              <span class="cert-name mono">{certsEarned[1].title}</span>
              {certsEarned[1].url && (
                <a href={certsEarned[1].url} target="_blank" rel="noopener noreferrer" class="cert-link mono">↗</a>
              )}
            </div>
            {certsEarned[1].sub && <p class="cert-sub mono">{certsEarned[1].sub}</p>}
            <p class="cert-issuer mono">{certsEarned[1].issuer}</p>
          </div>
          <div class="cert-item cert-item--wip cert-item--last">
            <div class="cert-name-row">
              <span class="cert-name mono">{certsWip[1].title}</span>
              <span class="wip-badge mono">wip</span>
            </div>
            <p class="cert-issuer mono">{certsWip[1].issuer}</p>
          </div>

        </div>
      </div>

    </div>
  </section>
)}

<style>
  .tech-stack {
    padding: 8px 28px 32px;
  }

  .ts-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .section-title-row {
    display: flex;
    align-items: baseline;
    gap: 10px;
    margin-bottom: 16px;
  }

  .title-prefix { font-size: 14px; color: var(--accent); }
  .title-text   { font-size: 28px; }
  .title-sub    { font-size: 11px; color: var(--ink-soft); }

  .ts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
    margin-bottom: 14px;
  }

  .ts-box {
    border: 1.5px dashed var(--ink);
    border-radius: 4px;
    padding: 12px;
    padding-top: 16px;
    position: relative;
    background: var(--paper);
  }

  .ts-label {
    position: absolute;
    top: -9px;
    left: 10px;
    background: var(--paper);
    padding: 0 6px;
    font-size: 9px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }

  .ts-pills {
    display: flex;
    flex-wrap: wrap;
    margin-top: 4px;
  }

  .ts-pill {
    display: inline-block;
    padding: 3px 9px;
    border: 1.5px dashed var(--ink);
    border-radius: 999px;
    font-size: 10px;
    margin-right: 5px;
    margin-bottom: 5px;
    color: var(--ink);
  }

  /* Certifications box */
  .cert-box {
    padding-top: 20px;
  }

  /* 2-col grid: certs side by side so rows share the same height → dividers align */
  .cert-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0 32px;
    margin-top: 8px;
  }

  .cert-col-label {
    font-size: 9px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    padding-bottom: 10px;
    border-bottom: 1px dashed var(--ink-soft);
    margin-bottom: 0;
  }

  .cert-col-label--wip {
    color: var(--ink-soft);
  }

  /* Each cert occupies a grid cell; bottom border acts as row divider */
  .cert-item {
    padding: 12px 0;
    border-bottom: 1px dashed var(--ink-soft);
    /* grid stretches both cells in a row to the same height → dividers align */
    align-self: stretch;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .cert-item--last {
    border-bottom: none;
  }

  .cert-item--wip {
    opacity: 0.6;
  }

  .cert-name-row {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 3px;
    flex-wrap: wrap;
  }

  .cert-name {
    font-size: 11px;
    color: var(--ink);
    font-weight: 600;
  }

  .cert-link {
    font-size: 10px;
    color: var(--accent);
    text-decoration: none;
    border: 1px solid var(--accent);
    border-radius: 999px;
    padding: 0px 5px;
    line-height: 1.6;
    transition: background 0.15s, color 0.15s;
  }

  .cert-link:hover {
    background: var(--accent);
    color: var(--paper);
  }

  .wip-badge {
    font-size: 8px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-soft);
    border: 1px dashed var(--ink-soft);
    border-radius: 999px;
    padding: 0px 5px;
    line-height: 1.6;
  }

  .cert-sub {
    font-size: 9px;
    color: var(--ink-soft);
    margin-bottom: 3px;
    line-height: 1.5;
  }

  .cert-issuer {
    font-size: 9px;
    color: var(--ink-soft);
    opacity: 0.7;
  }

  @media (max-width: 680px) {
    .ts-grid    { grid-template-columns: 1fr; }
    .title-sub  { display: none; }

    .cert-grid  { grid-template-columns: 1fr; gap: 0; }

    /* Reorder so earned certs stay together, then WIP certs together */
    .cert-grid > :nth-child(1) { order: 1; }  /* ✓ earned label */
    .cert-grid > :nth-child(3) { order: 2; }  /* Adobe */
    .cert-grid > :nth-child(5) { order: 3; }  /* ML Spec */
    .cert-grid > :nth-child(2) { order: 4; margin-top: 8px; } /* ○ in progress label */
    .cert-grid > :nth-child(4) { order: 5; }  /* Claude */
    .cert-grid > :nth-child(6) { order: 6; }  /* AWS ML */

    /* Restore bottom borders in new order */
    .cert-item              { border-bottom: 1px dashed var(--ink-soft); }
    .cert-grid > :nth-child(6) { border-bottom: none; }
  }
</style>
