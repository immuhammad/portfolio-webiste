---
import { SITE } from '../config';

// Fetch GitHub contribution graph at build time
let contributions: number[][] = [];
let totalSessions = 0;

try {
  const res = await fetch(
    `https://github-contributions-api.jogruber.de/v4/${SITE.github}?y=last`,
    { signal: AbortSignal.timeout(5000) }
  );
  if (res.ok) {
    const data = await res.json() as {
      contributions: { date: string; count: number; level: number }[];
      total: Record<string, number>;
    };
    // Build a 7-row × 26-col grid (most recent 26 weeks)
    const flat = data.contributions.slice(-182).map(d => d.level); // 26*7=182
    for (let col = 0; col < 26; col++) {
      const week: number[] = [];
      for (let row = 0; row < 7; row++) {
        week.push(flat[col * 7 + row] ?? 0);
      }
      contributions.push(week);
    }
    totalSessions = Object.values(data.total).reduce((a, b) => a + b, 0);
  }
} catch {
  // TODO: GitHub API unavailable at build time — using static placeholder
}

// Fallback: static placeholder grid
if (contributions.length === 0) {
  contributions = Array.from({ length: 26 }, () =>
    Array.from({ length: 7 }, () => Math.floor(Math.random() * 3))
  );
  totalSessions = 0;
}

const levelColors = [
  'var(--paper-2)',
  'rgba(184,99,72,0.25)',
  'rgba(184,99,72,0.55)',
  'var(--accent)',
];

// Hardcoded log entries — replace with real study sessions in Task 6
const logEntries = [
  { date: 'Today',     text: 'Built RAG demo over my notes (LangChain + Chroma)' },
  { date: 'Yesterday', text: 'Finished week 3 of fast.ai · CNN intuition' },
  { date: '2d ago',    text: 'Wrote a tiny transformer from scratch in PyTorch' },
  { date: '5d ago',    text: 'Cert: AWS ML Foundations · in progress 60%' },
];
---

{SITE.sections.learningLog && (
  <section class="learning-log section-pad">
    <div class="ll-inner">
      <h2 class="section-title">
        <span class="prefix">❯ </span>Learning Log
      </h2>

      <!-- Contribution graph -->
      <div class="contrib-wrap">
        <div class="contrib-grid">
          {contributions.map((week) =>
            week.map((level) => (
              <span
                class="contrib-cell"
                style={`background: ${levelColors[Math.min(level, 3)]}`}
              />
            ))
          )}
        </div>
        <div class="contrib-meta mono ink-soft">
          {totalSessions > 0
            ? `~${totalSessions} study sessions in the last year`
            : 'contribution graph (live at build time)'}
          <span class="legend">
            <span>less</span>
            {levelColors.map(c => (
              <span class="legend-cell" style={`background: ${c}`} />
            ))}
            <span>more</span>
          </span>
        </div>
      </div>

      <!-- Log entries -->
      <div class="log-grid">
        {logEntries.map((e) => (
          <div class="log-entry">
            <span class="log-date mono accent">{e.date}</span>
            <p class="log-text mono">{e.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
)}

<style>
  .learning-log {
    padding: 4rem 2rem;
    background: var(--paper-2);
    border-top: var(--border);
    border-bottom: var(--border);
  }

  .ll-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .contrib-wrap {
    margin-bottom: 2.5rem;
  }

  .contrib-grid {
    display: grid;
    grid-template-columns: repeat(26, 1fr);
    grid-template-rows: repeat(7, 1fr);
    grid-auto-flow: column;
    gap: 3px;
    max-width: 520px;
    margin-bottom: 0.5rem;
  }

  .contrib-cell {
    aspect-ratio: 1;
    border-radius: 2px;
  }

  .contrib-meta {
    font-size: 0.6875rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .legend {
    display: flex;
    align-items: center;
    gap: 3px;
    font-size: 0.5625rem;
  }

  .legend-cell {
    width: 10px;
    height: 10px;
    border-radius: 2px;
    display: inline-block;
  }

  .log-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .log-entry {
    border-left: 2px solid var(--accent);
    padding-left: 0.75rem;
  }

  .log-date {
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    display: block;
    margin-bottom: 0.2rem;
  }

  .log-text {
    font-size: 0.6875rem;
    line-height: 1.5;
    color: var(--ink);
  }

  @media (max-width: 600px) {
    .log-grid { grid-template-columns: 1fr; }
  }
</style>
