---
import { SITE } from '../config';

// ── Fetch GitHub contribution graph at build time ──────────────────────────
let cells: number[] = [];
let totalSessions = 0;

const COLS = 26;
const ROWS = 7;

try {
  const res = await fetch(
    `https://github-contributions-api.jogruber.de/v4/${SITE.github}?y=last`,
    { signal: AbortSignal.timeout(5000) }
  );
  if (res.ok) {
    const data = await res.json() as {
      contributions: { date: string; count: number; level: number }[];
      total: Record<string, number>;
    };
    const flat = data.contributions.slice(-(COLS * ROWS)).map(d => d.level);
    cells = flat;
    totalSessions = Object.values(data.total).reduce((a, b) => a + b, 0);
  }
} catch {
  // TODO: GitHub API unavailable at build time — using static placeholder
}

// Fallback: deterministic fake grid (biased toward recent activity)
if (cells.length === 0) {
  for (let c = 0; c < COLS; c++) {
    for (let r = 0; r < ROWS; r++) {
      const recency = c / COLS;
      const seed = (c * 7 + r * 3) % 11;
      const v = seed > 9 - recency * 6 ? 3 : seed > 7 - recency * 5 ? 2 : seed > 5 - recency * 4 ? 1 : 0;
      cells.push(v);
    }
  }
}

const shades = [
  'var(--paper-2)',
  'rgba(184,99,72,0.25)',
  'rgba(184,99,72,0.55)',
  'var(--accent)',
];

// Log entries — replace with real sessions in Task 6
const logEntries = [
  { date: 'Today',     text: 'Built RAG demo over my notes (LangChain + Chroma)' },
  { date: 'Yesterday', text: 'Finished week 3 of fast.ai · CNN intuition' },
  { date: '2d ago',    text: 'Wrote a tiny transformer from scratch in PyTorch' },
  { date: '5d ago',    text: 'Cert: AWS ML Foundations · in progress 60%' },
];

const statLabel = totalSessions > 0
  ? `~${totalSessions} study sessions in the last year`
  : '~340 study sessions in the last year';

// Toggle: set SITE.sections.learningLog = false in src/config.ts to hide
---

{SITE.sections.learningLog && (
  <section class="learning-log">
    <div class="ll-inner">

      <!-- Section title -->
      <div class="section-title-row">
        <span class="title-prefix mono">❯</span>
        <span class="title-text hand">Learning Log</span>
        <span class="title-sub mono">— public commits to the AI journey</span>
      </div>

      <!-- Dashed Box wrapping everything -->
      <div class="ll-box">

        <!-- Top row: stat label + legend -->
        <div class="ll-header">
          <span class="ll-stat mono">{statLabel}</span>
          <div class="legend mono">
            <span>less</span>
            {shades.map(sh => (
              <span class="legend-cell" style={`background:${sh}`} />
            ))}
            <span>more</span>
          </div>
        </div>

        <!-- Contribution grid: 7 rows × 26 cols, column-major flow -->
        <div class="contrib-grid">
          {cells.map((v) => (
            <span class="contrib-cell" style={`background:${shades[Math.min(v, 3)]}`} />
          ))}
        </div>

        <!-- Log entries: 2-col grid -->
        <div class="log-grid">
          {logEntries.map(e => (
            <div class="log-entry">
              <span class="log-date mono">{e.date}</span>
              <p class="log-text mono">{e.text}</p>
            </div>
          ))}
        </div>

      </div>
    </div>
  </section>
)}

<style>
  .learning-log {
    padding: 8px 28px 32px;
  }

  .ll-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  /* Section title */
  .section-title-row {
    display: flex;
    align-items: baseline;
    gap: 10px;
    margin-bottom: 16px;
  }

  .title-prefix { font-size: 14px; color: var(--accent); }
  .title-text   { font-size: 28px; }
  .title-sub    { font-size: 11px; color: var(--ink-soft); }

  /* Dashed Box — matches wireframe Box component */
  .ll-box {
    border: 1.5px dashed var(--ink);
    border-radius: 4px;
    padding: 18px;
    background: var(--paper);
  }

  /* Stat + legend row */
  .ll-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
  }

  .ll-stat {
    font-size: 11px;
    color: var(--ink-soft);
  }

  .legend {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 9px;
    color: var(--ink-soft);
  }

  .legend-cell {
    display: inline-block;
    width: 10px;
    height: 10px;
    border: 1px solid var(--ink-soft);
  }

  /* Contribution grid — column-major (7 rows × 26 cols) */
  .contrib-grid {
    display: grid;
    grid-template-columns: repeat(26, 1fr);
    grid-template-rows: repeat(7, 12px);
    grid-auto-flow: column;
    gap: 3px;
  }

  .contrib-cell {
    border: 1px solid var(--ink-soft);
    border-radius: 1px;
  }

  /* Log entries */
  .log-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
    margin-top: 18px;
  }

  .log-entry {
    border-left: 2px solid var(--accent);
    padding-left: 10px;
  }

  .log-date {
    display: block;
    font-size: 9px;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .log-text {
    font-size: 11px;
    line-height: 1.5;
    margin-top: 2px;
    color: var(--ink);
  }

  @media (max-width: 600px) {
    .log-grid { grid-template-columns: 1fr; }
    .title-sub { display: none; }
  }
</style>
