---
const nowPills  = ['PHP', 'Laravel', 'Magento 2', 'MySQL', 'REST APIs', 'Shopify'];
const nextPills = ['Python', 'PyTorch', 'LangChain', 'Pandas', 'SQL', 'Airflow'];

const nowBullets = [
  'Maintaining multi-tenant Magento 2 stores',
  'Building custom Laravel APIs for clients',
  'Integrating Shopify with back-office systems',
];

const nextBullets = [
  'MSc AI coursework + fast.ai curriculum',
  'Building RAG pipelines with LangChain + Chroma',
  'Experimenting with data pipelines and Airflow',
];
---

<section class="now-next section-pad" id="ai-world">
  <div class="now-next-inner">
    <h2 class="section-title">
      <span class="prefix">❯ </span>Now / Next
    </h2>

    <div class="nn-grid">
      <!-- NOW -->
      <div class="nn-box nn-now">
        <h3 class="nn-title hand">Backend / E-commerce</h3>
        <div class="nn-pills">
          {nowPills.map(p => <span class="pill">{p}</span>)}
        </div>
        <ul class="nn-list mono">
          {nowBullets.map(b => <li>{b}</li>)}
        </ul>
      </div>

      <!-- Arrow -->
      <div class="nn-arrow" aria-hidden="true">
        <svg viewBox="0 0 60 80" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M30 10 C10 20, 10 55, 30 65" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" fill="none"/>
          <path d="M22 58 L30 68 L38 58" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
        </svg>
        <span class="nn-arrow-label hand accent">phasing</span>
      </div>

      <!-- NEXT -->
      <div class="nn-box nn-next">
        <h3 class="nn-title hand">AI / Data Engineering</h3>
        <div class="nn-pills">
          {nextPills.map(p => <span class="pill">{p}</span>)}
        </div>
        <ul class="nn-list mono">
          {nextBullets.map(b => <li>{b}</li>)}
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .now-next {
    padding: 4rem 2rem;
  }

  .now-next-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .nn-grid {
    display: grid;
    grid-template-columns: 1fr 60px 1fr;
    gap: 1rem;
    align-items: start;
  }

  .nn-box {
    border: var(--border);
    border-radius: var(--radius);
    padding: 1.5rem;
  }

  .nn-now  { background: var(--paper); }
  .nn-next { background: var(--paper-2); }

  .nn-title {
    font-size: 1.375rem;
    margin-bottom: 1rem;
  }

  .nn-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1rem;
  }

  .nn-list {
    list-style: none;
    font-size: 0.6875rem;
    color: var(--ink-soft);
    line-height: 1.7;
  }

  .nn-list li::before {
    content: '– ';
    color: var(--accent);
  }

  .nn-arrow {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 2rem;
    gap: 0.25rem;
  }

  .nn-arrow svg {
    width: 40px;
    height: 56px;
  }

  .nn-arrow-label {
    font-size: 0.875rem;
    writing-mode: vertical-rl;
    transform: rotate(180deg);
  }

  @media (max-width: 680px) {
    .nn-grid {
      grid-template-columns: 1fr;
    }
    .nn-arrow {
      display: none;
    }
  }
</style>
