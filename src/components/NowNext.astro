---
const nowPills  = ['PHP', 'Laravel', 'Magento 2', 'MySQL', 'REST APIs', 'Shopify'];
const nextPills = ['Python', 'PyTorch', 'LangChain', 'LlamaIndex', 'HuggingFace', 'Ollama', 'Pandas', 'SQL', 'Airflow', 'Claude Code'];

const nowBullets = [
  'Maintaining custom Magento stores',
  'Building Shopify plugins (Laravel)',
  'Magento extensions & integrations',
];

const nextBullets = [
  'Studying ML fundamentals + DL',
  'Building LLM apps & agents',
  'Data pipelines, ETL, warehousing',
  'Agentic coding with Claude Code',
];
---

<section class="now-next" id="ai-world">
  <div class="nn-inner">
    <!-- Section title with subtitle — exact wireframe pattern -->
    <div class="section-title-row">
      <span class="title-prefix mono">❯</span>
      <span class="title-text hand">Now / Next</span>
      <span class="title-sub mono">— where I am · where I'm going</span>
    </div>

    <div class="nn-grid">
      <!-- NOW box: dashed border + floating label -->
      <div class="nn-box nn-now">
        <span class="box-label mono">// NOW</span>
        <h3 class="nn-title hand">Backend / E-commerce</h3>
        <div class="nn-pills">
          {nowPills.map(p => <span class="pill">{p}</span>)}
        </div>
        <ul class="nn-list mono">
          {nowBullets.map(b => <li>{b}</li>)}
        </ul>
      </div>

      <!-- Arrow -->
      <div class="nn-arrow" aria-hidden="true">
        <svg width="52" height="52" viewBox="0 0 52 52">
          <!-- Arc from top-left to mid-right -->
          <path d="M 8 10 Q 8 40 36 40" fill="none" stroke="var(--accent)" stroke-width="2.5" stroke-linecap="round" />
          <!-- Arrowhead at (36,40) pointing right -->
          <path d="M 26 32 L 36 40 L 26 48" fill="none" stroke="var(--accent)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        <span class="arrow-label hand accent">phasing</span>
      </div>

      <!-- NEXT box: dashed border + floating label + paper-2 bg -->
      <div class="nn-box nn-next">
        <span class="box-label mono">// NEXT</span>
        <h3 class="nn-title hand">AI / Data Engineering</h3>
        <div class="nn-pills">
          {nextPills.map(p => <span class="pill">{p}</span>)}
        </div>
        <ul class="nn-list mono">
          {nextBullets.map(b => <li>{b}</li>)}
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .now-next {
    padding: 8px 28px 32px;
  }

  .nn-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  /* Section title row — prefix + title + subtitle on one baseline */
  .section-title-row {
    display: flex;
    align-items: baseline;
    gap: 10px;
    margin-bottom: 16px;
  }

  .title-prefix {
    font-size: 14px;
    color: var(--accent);
  }

  .title-text {
    font-size: 28px;
  }

  .title-sub {
    font-size: 11px;
    color: var(--ink-soft);
  }

  /* 3-col grid: content | 72px arrow | content */
  .nn-grid {
    display: grid;
    grid-template-columns: 1fr 72px 1fr;
    gap: 0;
    align-items: stretch;
  }

  /* Box with dashed border + floating label (like wireframe Box component) */
  .nn-box {
    border: 1.5px dashed var(--ink);
    border-radius: 4px;
    padding: 12px;
    position: relative;
    min-height: 200px;
  }

  .nn-now { background: var(--paper); }
  .nn-next { background: var(--paper-2); }

  /* Floating label chip that sits on the top border */
  .box-label {
    position: absolute;
    top: -9px;
    left: 10px;
    background: var(--paper);
    padding: 0 6px;
    font-size: 9px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }

  .nn-next .box-label {
    background: var(--paper-2);
  }

  .nn-title {
    font-size: 22px;
    margin-bottom: 10px;
  }

  .nn-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0;
    margin-bottom: 10px;
  }

  /* Pills in wireframe have margin-right/bottom baked in */
  .nn-pills .pill {
    margin-right: 5px;
    margin-bottom: 5px;
    border-radius: 999px;
  }

  /* Standard ul bullets matching wireframe */
  .nn-list {
    font-size: 11px;
    line-height: 1.7;
    padding-left: 16px;
    color: var(--ink-soft);
    margin: 0;
  }

  /* Arrow column */
  .nn-arrow {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
  }

  .arrow-label {
    font-size: 14px;
    text-align: center;
  }

  @media (max-width: 680px) {
    .nn-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
    .nn-arrow { display: none; }
  }
</style>
