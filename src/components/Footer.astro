---
import { SITE } from '../config';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-inner">
    <span class="mono ink-soft">© {year} {SITE.name.toLowerCase()}</span>
    <span class="mono ink-soft">built with ♥ + a lot of coffee</span>
  </div>
</footer>

<style>
  .site-footer {
    border-top: var(--border);
    background: var(--paper);
  }

  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 1.25rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 0.625rem;
  }
</style>
