---
import { getCollection } from 'astro:content';
import { SITE } from '../config';

const allProjects = await getCollection('projects');
const phpProjects = allProjects
  .filter(p => p.data.category === 'php')
  .sort((a, b) => a.data.order - b.data.order);
const aiProjects = allProjects
  .filter(p => p.data.category === 'ai')
  .sort((a, b) => a.data.order - b.data.order);
---

{SITE.sections.projects && (
  <section class="projects section-pad" id="projects">
    <div class="projects-inner">
      <h2 class="section-title">
        <span class="prefix">❯ </span>Projects
      </h2>

      <!-- Tab bar -->
      <div class="tabs" role="tablist">
        <button class="tab tab--active" role="tab" data-tab="php" aria-selected="true">
          ⚡ Production (PHP)
        </button>
        <button class="tab" role="tab" data-tab="ai" aria-selected="false">
          🧠 Learning (AI)
        </button>
      </div>

      <!-- PHP panel -->
      <div class="tab-panel" id="panel-php" role="tabpanel">
        <div class="card-grid">
          {phpProjects.length > 0
            ? phpProjects.map(p => (
                <div class="project-card">
                  <div class="card-screenshot hatch-placeholder" aria-hidden="true" />
                  <div class="card-body">
                    <h3 class="card-title hand">{p.data.title}</h3>
                    <p class="card-tag mono ink-soft">{p.data.tag}</p>
                  </div>
                </div>
              ))
            : <p class="mono ink-soft empty-note">No PHP projects yet — add them in src/content/projects/</p>
          }
        </div>
      </div>

      <!-- AI panel (hidden by default) -->
      <div class="tab-panel tab-panel--hidden" id="panel-ai" role="tabpanel">
        <div class="card-grid">
          {aiProjects.length > 0
            ? aiProjects.map(p => (
                <div class="project-card">
                  <div class="card-screenshot hatch-placeholder" aria-hidden="true" />
                  <div class="card-body">
                    <h3 class="card-title hand">{p.data.title}</h3>
                    <p class="card-tag mono ink-soft">{p.data.tag}</p>
                  </div>
                </div>
              ))
            : <p class="mono ink-soft empty-note">No AI projects yet — add them in src/content/projects/</p>
          }
        </div>
      </div>

      <div class="projects-footer">
        <a href={`https://github.com/${SITE.github}`} class="pill" target="_blank" rel="noopener">
          see all on GitHub →
        </a>
      </div>
    </div>
  </section>
)}

<style>
  .projects {
    padding: 4rem 2rem;
  }

  .projects-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .tabs {
    display: flex;
    gap: 0;
    margin-bottom: 1.5rem;
    border-bottom: var(--border);
  }

  .tab {
    font-family: var(--mono);
    font-size: 0.75rem;
    padding: 0.6rem 1.1rem;
    background: none;
    border: none;
    border-bottom: 3px solid transparent;
    cursor: pointer;
    color: var(--ink-soft);
    margin-bottom: -1.5px;
    transition: color 0.15s;
  }

  .tab--active {
    color: var(--ink);
    border-bottom-color: var(--accent);
  }

  .tab-panel--hidden {
    display: none;
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .project-card {
    border: var(--border);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .card-screenshot {
    height: 140px;
    border-bottom: var(--border);
  }

  .card-body {
    padding: 0.9rem 1rem;
  }

  .card-title {
    font-size: 1.125rem;
    margin-bottom: 0.25rem;
  }

  .card-tag {
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .empty-note {
    font-size: 0.75rem;
    padding: 1rem 0;
  }

  .projects-footer {
    margin-top: 0.5rem;
  }

  @media (max-width: 600px) {
    .card-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.tab');
  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => {
        t.classList.remove('tab--active');
        t.setAttribute('aria-selected', 'false');
      });
      tab.classList.add('tab--active');
      tab.setAttribute('aria-selected', 'true');

      const target = tab.dataset.tab;
      document.querySelectorAll('.tab-panel').forEach(panel => {
        panel.classList.toggle('tab-panel--hidden', panel.id !== `panel-${target}`);
      });
    });
  });
</script>
