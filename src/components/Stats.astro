---
import { SITE } from '../config';

const stats = [
  { value: SITE.stats.years,    label: 'Years in production' },
  { value: SITE.stats.projects, label: 'Projects shipped' },
  { value: SITE.stats.stacks,   label: 'Stacks (PHP + AI)' },
];
---

<section class="stats-band">
  <div class="stats-inner">
    {stats.map((s) => (
      <div class="stat-card">
        <span class="stat-value hand">{s.value}</span>
        <span class="stat-label mono">{s.label}</span>
      </div>
    ))}
  </div>
</section>

<style>
  .stats-band {
    background: var(--paper-2);
    border-top: var(--border);
    border-bottom: var(--border);
  }

  .stats-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 2rem;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .stat-card {
    border: var(--border);
    border-radius: var(--radius);
    background: var(--paper);
    padding: 1.5rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .stat-value {
    font-size: 2.375rem;
    font-weight: 700;
    line-height: 1;
    color: var(--ink);
  }

  .stat-label {
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--ink-soft);
  }

  @media (max-width: 600px) {
    .stats-inner {
      grid-template-columns: 1fr;
    }
  }
</style>
