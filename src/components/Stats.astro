---
import { SITE } from '../config';

const stats = [
  { value: SITE.stats.years,    label: 'PHP/ Laravel/ Shopify/ Magento', link: '' },
  { value: SITE.stats.projects, label: 'Projects Shipped',               link: '' },
  { value: SITE.stats.stacks,   label: 'Certs (Live · WIP)',             link: '#certifications' },
];
---

<div class="stats-wrap">
  <div class="stats-inner">
    {stats.map((s) => (
      <div class="stat-card">
        {s.link
          ? <a href={s.link} class="stat-value hand stat-link">{s.value}</a>
          : <span class="stat-value hand">{s.value}</span>
        }
        <span class="stat-label mono">{s.label}</span>
      </div>
    ))}
  </div>
</div>

<style>
  .stats-wrap {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 28px 32px;
  }

  .stats-inner {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
  }

  .stat-card {
    border: 1.5px solid var(--ink);
    border-radius: 4px;
    padding: 16px;
    background: var(--paper-2);
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .stat-value {
    font-size: 38px;
    line-height: 1;
    color: var(--ink);
  }

  .stat-link {
    text-decoration: none;
    border-bottom: 2px solid var(--accent);
    display: inline-block;
    transition: color 0.15s;
  }

  .stat-link:hover {
    color: var(--accent);
  }

  .stat-label {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--ink-soft);
  }

  @media (max-width: 600px) {
    .stats-inner { grid-template-columns: 1fr; }
  }
</style>
