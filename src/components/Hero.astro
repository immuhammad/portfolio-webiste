---
import { SITE } from '../config';

interface Props {
  photoSrc?: string;
}
const { photoSrc } = Astro.props;
---

<section class="hero">
  <div class="hero-inner">
    <!-- Photo -->
    <div class="hero-photo">
      {photoSrc
        ? <img src={photoSrc} alt={SITE.name} class="photo-img" />
        : <div class="photo-placeholder" aria-label="Photo placeholder">
            <svg
              class="placeholder-x"
              preserveAspectRatio="none"
              viewBox="0 0 100 100"
              aria-hidden="true"
            >
              <line x1="0" y1="0" x2="100" y2="100" stroke="var(--ink)" stroke-width="0.4" stroke-dasharray="2 2" vector-effect="non-scaling-stroke" />
              <line x1="100" y1="0" x2="0" y2="100" stroke="var(--ink)" stroke-width="0.4" stroke-dasharray="2 2" vector-effect="non-scaling-stroke" />
            </svg>
            <span class="placeholder-label mono">photo of you</span>
          </div>
      }
    </div>

    <!-- Text -->
    <div class="hero-text">
      <p class="hero-tag mono accent">Two stacks. One engineer.</p>

      <h1 class="hero-h1 hand">
        PHP shops by day.<br />PyTorch notebooks by night.
      </h1>

      <!-- Squiggle underline — width matches wireframe (140px) -->
      <svg class="squiggle" width="140" height="6" viewBox="0 0 140 6" aria-hidden="true">
        <path
          d="M 0 3 Q 17.5 0 35 3 T 70 3 T 105 3 T 140 3"
          fill="none"
          stroke="var(--accent)"
          stroke-width="2"
          stroke-linecap="round"
        />
      </svg>

      <p class="hero-sub mono ink-soft">
        I keep production e-commerce running while I retool for the AI stack. Both worlds, in public.
      </p>

      <div class="hero-ctas">
        <a href={`mailto:${SITE.email}`} class="cta-pill cta-pill--accent mono">$ get_in_touch</a>
        <a href="#projects" class="cta-pill mono">view projects →</a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: 24px 28px 8px;
    max-width: 1100px;
    margin: 0 auto;
  }

  .hero-inner {
    display: flex;
    gap: 36px;
    align-items: flex-end;
  }

  /* ── Photo placeholder (wireframe-accurate) ── */
  .hero-photo {
    flex-shrink: 0;
  }

  .photo-img {
    width: 260px;
    height: 340px;
    object-fit: cover;
    object-position: top center;
    display: block;
  }

  .photo-img[src$=".png"] {
    object-fit: contain;
    object-position: bottom center;
    filter: drop-shadow(4px 8px 20px rgba(34, 32, 24, 0.30));
  }

  .photo-placeholder {
    width: 200px;
    height: 240px;
    border: 1.5px dashed var(--ink);
    border-radius: 4px;
    background: repeating-linear-gradient(
      45deg,
      transparent 0 8px,
      rgba(0, 0, 0, 0.05) 8px 9px
    );
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .placeholder-x {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .placeholder-label {
    font-size: 10px;
    color: var(--ink-soft);
    background: var(--paper);
    padding: 2px 6px;
    position: relative;
    z-index: 1;
  }

  /* ── Text ── */
  .hero-tag {
    font-size: 11px;
    letter-spacing: 0.04em;
    margin-bottom: 10px;
  }

  .hero-h1 {
    font-size: 38px;
    line-height: 1.15;
    font-weight: 400;
    letter-spacing: -0.01em;
    margin: 0 0 6px;
  }

  .squiggle {
    display: block;
    margin-bottom: 16px;
  }

  .hero-sub {
    font-size: 12px;
    line-height: 1.6;
    max-width: 460px;
    margin-bottom: 18px;
  }

  .hero-ctas {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .cta-pill {
    display: inline-block;
    padding: 3px 9px;
    border: 1.5px dashed var(--ink);
    border-radius: 999px;
    font-size: 10px;
    color: var(--ink);
    text-decoration: none;
    transition: opacity 0.15s;
  }

  .cta-pill--accent {
    border-style: solid;
    background: var(--accent);
    color: #fff;
  }

  .cta-pill:hover {
    opacity: 0.8;
  }

  @media (max-width: 640px) {
    .hero-inner {
      flex-direction: column;
      align-items: center;
    }
    .hero-photo { display: none; }
    .hero-text  { text-align: center; }
    .hero-ctas  { justify-content: center; }
    .squiggle   { margin: 0 auto 16px; }
  }
</style>
