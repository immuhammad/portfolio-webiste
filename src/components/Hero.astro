---
import { SITE } from '../config';

interface Props {
  photoSrc?: string;
}
const { photoSrc } = Astro.props;
---

<section class="hero">
  <div class="hero-inner">
    <div class="hero-photo">
      {photoSrc
        ? <img src={photoSrc} alt={SITE.name} class="photo-img" />
        : <div class="photo-placeholder hatch-placeholder" aria-hidden="true">
            <span class="photo-label mono ink-soft">photo</span>
          </div>
      }
    </div>

    <div class="hero-text">
      <p class="hero-tag mono accent">Two stacks. One engineer.</p>

      <h1 class="hero-h1 hand">
        PHP shops by day.<br />PyTorch notebooks<br />by night.
      </h1>

      <svg class="squiggle" viewBox="0 0 260 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M2 7 C20 2, 40 12, 60 7 S100 2, 120 7 S160 12, 180 7 S220 2, 258 7"
          stroke="var(--accent)" stroke-width="2.5" stroke-linecap="round" fill="none"/>
      </svg>

      <p class="hero-sub mono ink-soft">
        8 years building production PHP — Magento, Laravel, Shopify.<br />
        Now layering in Python, PyTorch, and LangChain.
      </p>

      <div class="hero-ctas">
        <a href={`mailto:${SITE.email}`} class="pill pill--accent cta-pill">$ get_in_touch</a>
        <a href="#projects" class="pill cta-pill">view projects →</a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: 4rem 2rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 3rem;
    align-items: center;
  }

  .hero-photo {
    width: 200px;
    height: 240px;
    flex-shrink: 0;
  }

  .photo-img {
    width: 200px;
    height: 240px;
    object-fit: cover;
    border-radius: var(--radius);
    border: var(--border);
  }

  .photo-placeholder {
    width: 200px;
    height: 240px;
    border: 1.5px dashed var(--ink-soft);
    border-radius: var(--radius);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 1;
  }

  .photo-label {
    font-size: 0.6875rem;
    opacity: 0.6;
  }

  .hero-tag {
    font-size: 0.6875rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  .hero-h1 {
    font-size: 2.375rem;
    line-height: 1.15;
    color: var(--ink);
    margin-bottom: 0.5rem;
  }

  .squiggle {
    width: 260px;
    height: 14px;
    margin-bottom: 1.25rem;
  }

  .hero-sub {
    font-size: 0.75rem;
    line-height: 1.7;
    max-width: 460px;
    margin-bottom: 1.75rem;
  }

  .hero-ctas {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .cta-pill {
    font-size: 0.75rem;
    padding: 0.4em 1em;
    border-radius: var(--radius);
  }

  @media (max-width: 680px) {
    .hero-inner {
      grid-template-columns: 1fr;
    }
    .hero-photo {
      width: 140px;
      height: 168px;
    }
    .photo-img,
    .photo-placeholder {
      width: 140px;
      height: 168px;
    }
  }
</style>
